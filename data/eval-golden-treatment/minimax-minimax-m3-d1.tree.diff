diff --git a/scripts/run-focused.cjs b/scripts/run-focused.cjs
new file mode 100644
index 0000000..a44d18e
--- /dev/null
+++ b/scripts/run-focused.cjs
@@ -0,0 +1,38 @@
+#!/usr/bin/env node
+// Run a single scenario or a batch from a Cucumber watchbill in the canonical
+// "<spec>.feature:<Scenario Name>" reference form. Accepts one or more
+// references on the command line; deduplicates by feature file and runs the
+// union of named scenarios in one cucumber invocation so ambient setup
+// amortizes across the batch.
+
+const { spawnSync } = require("node:child_process");
+const path = require("node:path");
+
+function parseReferences(args) {
+  const refs = args.filter((a) => a.includes(":"));
+  if (refs.length === 0) {
+    process.stderr.write("usage: run-focused.cjs <spec>.feature:<Scenario> [...]\n");
+    process.exit(2);
+  }
+  const files = new Set();
+  const names = [];
+  for (const ref of refs) {
+    const idx = ref.lastIndexOf(":");
+    if (idx < 1) {
+      process.stderr.write(`malformed reference: ${ref}\n`);
+      process.exit(2);
+    }
+    files.add(ref.slice(0, idx));
+    names.push(ref.slice(idx + 1));
+  }
+  return { files: [...files], names };
+}
+
+const { files, names } = parseReferences(process.argv.slice(2));
+const args = [...files];
+for (const name of names) {
+  args.push("--name", name);
+}
+
+const result = spawnSync("npx", ["cucumber-js", ...args, "--tags", "not @captain and not @shipwright"], { stdio: "inherit" });
+process.exit(result.status === null ? 1 : result.status);
