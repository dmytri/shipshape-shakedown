+# Shipshape Rigging
+
+## Stack
+- language: JavaScript
+- runtime: node
+- packageManager: npm
+
+## Directories
+- implementation: src
+- specs: features
+- verification: features/support
+- assets: data
+
+## Commands
+- discover: npx cucumber-js --dry-run
+- focused: npx cucumber-js {scenario}
+- broad: npx cucumber-js
+- coverage: npx cucumber-js
+- step-usage: npx cucumber-js --format usage
+- plank-inventory: none
+- typecheck: none
+- lint: none
+
+## Perturbation
+- message: // PERTURBATION: rebuild this seam from current durable context
+- perturb: // PERTURBATION: rebuild this seam from current durable context
+
+## Tiers
+- default: @logic
+- policy: none
+- budget: none
+- weather: none
+- runrecord: none
+
+## Dependencies
+- policy: locked
+- dependency: @cucumber/cucumber
+
+## Outbound
+none
