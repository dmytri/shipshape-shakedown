+const { Given, Then } = require("@cucumber/cucumber");
+const assert = require("assert");
+const fs = require("fs");
+const path = require("path");
+const { execSync } = require("child_process");
+
+Given("no perturbation token exists in the implementation", function () {
+  const implDir = path.join(__dirname, "..", "..", "src");
+  const files = fs.readdirSync(implDir).filter(f => f.endsWith(".js"));
+  for (const file of files) {
+    const content = fs.readFileSync(path.join(implDir, file), "utf8");
+    assert.ok(!content.includes("PERTURBATION"), `Perturbation token found in ${file}`);
+  }
+});
+
+Given("no watchbill exists", function () {
+  const watchbillPath = path.join(__dirname, "..", "..", "watchbill.json");
+  assert.ok(!fs.existsSync(watchbillPath), "Watchbill file exists");
+});
