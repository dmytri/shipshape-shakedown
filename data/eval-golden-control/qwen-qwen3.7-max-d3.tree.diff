+{
+  "name": "verification-conformance",
+  "version": "1",
+  "description": "Shipshape methodology rule set for verification support conformance",
+  "rules": [
+    {
+      "id": "plank-form",
+      "name": "Plank form",
+      "description": "Every @planks and @planks-provisional annotation is a docblock tag on a declaration. Every @planks string matches a current step-definition pattern. Every @planks-provisional reference names a scenario that still carries @captain.",
+      "check": "grep -rn '@planks' src/ --include='*.js' | while read line; do if ! echo \"$line\" | grep -qP '^\\s*\\*'; then echo \"MALFORMED: $line\"; fi; done",
+      "scope": ["implementation"]
+    },
+    {
+      "id": "plank-coverage",
+      "name": "Plank coverage",
+      "description": "Every behaviour-bearing step-definition pattern from step-usage has at least one matching @planks token across implementation paths.",
+      "check": "Cross-reference step-usage patterns against plank-inventory output; a pattern with no matching plank token is a violation.",
+      "scope": ["implementation", "specs"],
+      "weakness": "Derived from text-pattern token search via jsdoc -X, not a full AST parser. May miss annotations in non-standard docblock forms."
+    },
+    {
+      "id": "forbidden-doubles",
+      "name": "Forbidden doubles",
+      "description": "No test double in verification support lacks the @exceptional-double inline mark with a named justification.",
+      "check": "Search verification support for sinon.mock, jest.mock, or similar double-creating calls. Each must be preceded by an @exceptional-double comment.",
+      "scope": ["verification"]
+    },
+    {
+      "id": "perturbation-quiescence",
+      "name": "Perturbation quiescence",
+      "description": "A green tree carries no PERTURBATION token in implementation directories.",
+      "check": "rg -l 'PERTURBATION' src/",
+      "scope": ["implementation"]
+    },
+    {
+      "id": "watchbill-shape",
+      "name": "Watchbill shape",
+      "description": "When watchbill.json exists it is valid JSON containing ordered watch objects with scenarios arrays. Absence conforms.",
+      "check": "If watchbill.json exists, validate it parses as JSON with watch1, watch2... keys each containing a scenarios array.",
+      "scope": ["root"]
+    }
+  ]
+}
