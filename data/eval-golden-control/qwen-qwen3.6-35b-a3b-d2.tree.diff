diff --git a/src/tide.js b/src/tide.js
index c3c80cc..cbe93a6 100644
--- a/src/tide.js
+++ b/src/tide.js
@@ -1,3 +1,9 @@
+/**
+ * @plank features/tides.feature:Next high tide after a given time
+ * @plank features/tides.feature:No upcoming high tide is an error
+ * @plank Seams: returns the first high tide chronologically after `after`.
+ *          Throws if none found.
+ */
 function nextHighTide(tides, after) {
   const next = tides.find((t) => new Date(t.time) > new Date(after) && t.type === "high");
   if (!next) throw new Error("no upcoming high tide in data");
