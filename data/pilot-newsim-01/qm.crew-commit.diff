@@ -1,7 +1,14 @@
+/** @planks("I ask for the next low tide after {string}") */
+function nextLowTide(tides, after) {
+  const next = tides.find((t) => new Date(t.time) > new Date(after) && t.type === "low");
+  if (!next) throw new Error("no upcoming low tide in data");
+  return next;
+}
+
 function nextHighTide(tides, after) {
   const next = tides.find((t) => new Date(t.time) > new Date(after) && t.type === "high");
   if (!next) throw new Error("no upcoming high tide in data");
   return next;
 }
 
-module.exports = { nextHighTide };
+module.exports = { nextHighTide, nextLowTide };
