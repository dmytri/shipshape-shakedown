+ *
+ * @param {Array} tides - Array of tide records.
+ * @param {string} after - ISO 8601 timestamp to search after.
+ * @returns {object} The next high tide record.
+ * @throws {Error} If no upcoming high tide exists in the data.
+ *
+ * @planks("I ask for the next high tide after {string}")
+ */
 function nextHighTide(tides, after) {
   const next = tides.find((t) => new Date(t.time) > new Date(after) && t.type === "high");
